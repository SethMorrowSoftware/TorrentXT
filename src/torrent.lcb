   end unsafe
   return tR
end handler

-- The v1 (or, absent v1, v2) info-hash as a hex string.
public handler btInfoHash(in pTorrent as Integer) returns String
   variable tCount as Integer
   _ensureScratch(kScratchCap)
   unsafe
      put _btx_info_hash_hex(pTorrent, sScratchPtr, sScratchCap) into tCount
   end unsafe
   if tCount < 0 then
      _ensureScratch(-tCount)
      unsafe
         put _btx_info_hash_hex(pTorrent, sScratchPtr, sScratchCap) into tCount
      end unsafe
   end if
   if tCount <= 0 then
      return ""
   end if
   return _decodeText(_bufToData(sScratchPtr, tCount), 1, tCount)
end handler

-- The packed piece have-bitfield as raw Data (1 bit per piece, MSB first).
public handler btPieceBitfield(in pTorrent as Integer) returns Data
   variable tCount as Integer
   _ensureStatus(kStatusCap)
   unsafe
      put _btx_piece_bitfield(pTorrent, sStatusPtr, sStatusCap) into tCount
   end unsafe
   if tCount < 0 then
      _ensureStatus(-tCount)
      unsafe
         put _btx_piece_bitfield(pTorrent, sStatusPtr, sStatusCap) into tCount
      end unsafe
   end if
   if tCount <= 0 then
      return the empty data
   end if
   return _bufToData(sStatusPtr, tCount)
end handler

-- Connected peers as a List of Arrays (keys: endpoint, client, downRate, ...).
public handler btPeerList(in pTorrent as Integer) returns List
   variable tPeers as List
   variable tCount as Integer
   variable tOffset as Integer
   variable tPeerCount as Integer
   variable tBodyLen as Integer
   variable tPeer as Array
   variable tI as Integer
   variable tBuf as Data
   put [] into tPeers
   _ensureStatus(kStatusCap)
   unsafe
      put _btx_peer_list(pTorrent, sStatusPtr, sStatusCap) into tCount
   end unsafe
   if tCount < 0 then
      _ensureStatus(-tCount)
      unsafe
         put _btx_peer_list(pTorrent, sStatusPtr, sStatusCap) into tCount
      end unsafe
   end if
   if tCount <= 0 then
      return tPeers
   end if
   put _bufToData(sStatusPtr, tCount) into tBuf
   put 1 into tOffset
   put _readU16(tBuf, tOffset) into tPeerCount
   add 2 to tOffset
   repeat with tI from 1 up to tPeerCount
      -- entry := [bodyLen:u16][kvrecord]; advance by the on-wire bodyLen
      put _readU16(tBuf, tOffset) into tBodyLen
      put _parseRecord(tBuf, tOffset + 2) into tPeer
      push tPeer onto tPeers
      add (2 + tBodyLen) to tOffset
   end repeat
   return tPeers
end handler

-- ===================================================================== --
--  Public API: the alert drain (the event firehose)
-- ===================================================================== --

-- Drain all pending events with ONE FFI round-trip and return them as a List
-- of Arrays. Each array has "code" (numeric), "name" (the semantic message),
-- "torrent" (our handle), plus event-specific keys. The poll dispatcher in
-- examples/torrent-helpers.livecodescript turns each into a sent message.
public handler btPoll(in pSession as Integer) returns List
   variable tEvents as List
   variable tCount as Integer
   variable tOffset as Integer
   variable tAlertCount as Integer
   variable tType as Integer
   variable tBodyLen as Integer
   variable tEvent as Array
   variable tI as Integer
   variable tBuf as Data
   put [] into tEvents
   _ensureDrain(kDrainCap)
   unsafe
      put _btx_pop_alerts(pSession, sDrainPtr, sDrainCap) into tCount
   end unsafe
   if tCount < 0 then
      -- even the first record did not fit; grow to the needed size and retry once
      _ensureDrain(-tCount)
      unsafe
         put _btx_pop_alerts(pSession, sDrainPtr, sDrainCap) into tCount
      end unsafe
   end if
   if tCount <= 0 then
      return tEvents
   end if
   -- IMPORTANT: btx_pop_alerts is the ONE buffer call that returns the ALERT
   -- COUNT on success, not a byte length (every other btx_* returns bytes). So
   -- copy the WHOLE buffer and let the on-wire framing bound the walk - the
   -- [alertCount:u16] header below is the loop count and each record carries its
   -- own bodyLen. The records sit at the front, so the loop stops after
   -- alertCount of them and the unused tail is never touched.
   put _bufToData(sDrainPtr, sDrainCap) into tBuf
   put 1 into tOffset
   put _readU16(tBuf, tOffset) into tAlertCount
   add 2 to tOffset
   repeat with tI from 1 up to tAlertCount
      -- entry := [alertType:u16][bodyLen:u16][kvrecord]
      put _readU16(tBuf, tOffset) into tType
      put _readU16(tBuf, tOffset + 2) into tBodyLen
      put _parseRecord(tBuf, tOffset + 4) into tEvent
      put tType into tEvent["code"]
      put _alertName(tType) into tEvent["name"]
      push tEvent onto tEvents
      add (4 + tBodyLen) to tOffset
   end repeat
   return tEvents
end handler

