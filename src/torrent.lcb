public handler btDhtLoadState(in pSession as Integer, in pData as Data) returns Integer
   variable tR as Integer
   variable tPtr as Pointer
   put 0 into tR
   if the number of bytes in pData > 0 then
      unsafe
         put MCDataGetBytePtr(pData) into tPtr
         put _btx_dht_load_state(pSession, tPtr, the number of bytes in pData) into tR
      end unsafe
   end if
   return tR
end handler

-- ===================================================================== --
--  Public API: BEP44 DHT key-value store
-- ===================================================================== --

-- Generate (pSeed empty) or deterministically re-derive (pSeed = 64-hex seed)
-- an ed25519 keypair for mutable items. Returns an Array {publicKey, secretKey,
-- seed} (all hex); persist the seed (or secretKey) to keep a stable identity.
public handler btDhtKeypair(in pSeed as String) returns Array
   variable tCount as Integer
   _ensureStatus(kStatusCap)
   unsafe
      put _btx_dht_keypair(pSeed, sStatusPtr, sStatusCap) into tCount
   end unsafe
   if tCount < 0 then
      _ensureStatus(-tCount)
      unsafe
         put _btx_dht_keypair(pSeed, sStatusPtr, sStatusCap) into tCount
      end unsafe
   end if
   if tCount <= 0 then
      return {}
   end if
   return _parseRecord(_bufToData(sStatusPtr, tCount), 1)
end handler

-- Store pData (1..1000 bytes) as an immutable item. Returns its target hash
-- (the lookup key) as hex, or "" on failure. The store confirms later as a
-- dhtPut event.
public handler btDhtPutImmutable(in pSession as Integer, in pData as Data) returns String
   variable tCount as Integer
   variable tPtr as Pointer
   variable tLen as Integer
   put the number of bytes in pData into tLen
   if tLen <= 0 then
      return ""
   end if
   _ensureScratch(kScratchCap)
   unsafe
      put MCDataGetBytePtr(pData) into tPtr
      put _btx_dht_put_immutable(pSession, tPtr, tLen, sScratchPtr, sScratchCap) into tCount
   end unsafe
   if tCount <= 0 then
      return ""
   end if
   return _decodeText(_bufToData(sScratchPtr, tCount), 1, tCount)
end handler

-- Look up an immutable item by its 40-hex target. The value arrives as a
-- dhtImmutableItem event (carrying target + value).
public handler btDhtGetImmutable(in pSession as Integer, in pTarget as String) returns Integer
   variable tR as Integer
   unsafe
      put _btx_dht_get_immutable(pSession, pTarget) into tR
   end unsafe
   return tR
end handler

-- Store pData (1..1000 bytes) as a mutable item under an ed25519 key; the
-- native layer signs it with pSecretKey (no script on the network thread).
-- pSalt may be empty. Confirms as a dhtPut event.
public handler btDhtPutMutable(in pSession as Integer, in pPublicKey as String, in pSecretKey as String, in pSalt as String, in pData as Data) returns Integer
   variable tR as Integer
   variable tPtr as Pointer
   variable tLen as Integer
   put the number of bytes in pData into tLen
   if tLen <= 0 then
      return -3
   end if
   unsafe
      put MCDataGetBytePtr(pData) into tPtr
      put _btx_dht_put_mutable(pSession, pPublicKey, pSecretKey, pSalt, tPtr, tLen) into tR
   end unsafe
   return tR
end handler

-- Look up a mutable item by its 64-hex public key (+ optional salt). The value
-- arrives as a dhtMutableItem event (value, seq, signature, authoritative).
public handler btDhtGetMutable(in pSession as Integer, in pPublicKey as String, in pSalt as String) returns Integer
   variable tR as Integer
   unsafe
      put _btx_dht_get_mutable(pSession, pPublicKey, pSalt) into tR
   end unsafe
   return tR
end handler

-- ===================================================================== --
--  Public API: create torrents (seeding side)
-- ===================================================================== --

-- Build a .torrent for pContentPath (file or directory) and return its bytes.
-- pPieceSize 0 == auto. pTrackers is an optional newline-separated list of
-- announce URLs (empty = trackerless / DHT-only). Empty Data on failure (see
-- btLastError).
public handler btCreateTorrent(in pContentPath as String, in pPieceSize as Integer, in pFlags as Integer, in pTrackers as String) returns Data
   variable tCount as Integer
   _ensureStatus(kStatusCap)
   unsafe
      put _btx_create_torrent(pContentPath, pPieceSize, pFlags, pTrackers, sStatusPtr, sStatusCap) into tCount
   end unsafe
   if tCount < 0 then
      _ensureStatus(-tCount)
      unsafe
         put _btx_create_torrent(pContentPath, pPieceSize, pFlags, pTrackers, sStatusPtr, sStatusCap) into tCount
      end unsafe
   end if
   if tCount <= 0 then
      return the empty data
   end if
   return _bufToData(sStatusPtr, tCount)
end handler

-- A library module must be closed with `end library` (matching the opening
-- `library ...` declaration) or OXT reports a syntax error at end-of-file.
end library
