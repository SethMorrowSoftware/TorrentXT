   else if pId is kFieldDhtNodeCache then
      return "nodeCache"
   else if pId is kFieldDhtGlobalNodes then
      return "globalNodes"
   else if pId is kFieldDhtTorrents then
      return "torrents"
   else if pId is kFieldDhtTarget then
      return "target"
   else if pId is kFieldDhtValue then
      return "value"
   else if pId is kFieldDhtPublicKey then
      return "publicKey"
   else if pId is kFieldDhtSignature then
      return "signature"
   else if pId is kFieldDhtSeq then
      return "seq"
   else if pId is kFieldDhtSalt then
      return "salt"
   else if pId is kFieldDhtAuthoritative then
      return "authoritative"
   else if pId is kFieldDhtNumSuccess then
      return "numSuccess"
   else if pId is kFieldDhtSecretKey then
      return "secretKey"
   else if pId is kFieldDhtSeed then
      return "seed"
   else
      return ""
   end if
end handler

-- Map a stable alert code to the semantic message name the poll dispatcher
-- sends (see examples/torrent-helpers.livecodescript).
private handler _alertName(in pCode as Integer) returns String
   if pCode is kAlertTorrentAdded then
      return "torrentAdded"
   else if pCode is kAlertMetadataReceived then
      return "metadataReceived"
   else if pCode is kAlertPieceFinished then
      return "pieceFinished"
   else if pCode is kAlertTorrentFinished then
      return "torrentFinished"
   else if pCode is kAlertTorrentError then
      return "torrentError"
   else if pCode is kAlertStateChanged then
      return "stateChanged"
   else if pCode is kAlertTrackerReply then
      return "trackerReply"
   else if pCode is kAlertTrackerError then
      return "trackerError"
   else if pCode is kAlertResumeDataReady then
      return "resumeDataReady"
   else if pCode is kAlertResumeDataFailed then
      return "resumeDataFailed"
   else if pCode is kAlertTorrentRemoved then
      return "torrentRemoved"
   else if pCode is kAlertDhtBootstrap then
      return "dhtBootstrap"
   else if pCode is kAlertListenSucceeded then
      return "listenSucceeded"
   else if pCode is kAlertListenFailed then
      return "listenFailed"
   else if pCode is kAlertTorrentPaused then
      return "torrentPaused"
   else if pCode is kAlertTorrentResumed then
      return "torrentResumed"
   else if pCode is kAlertFileCompleted then
      return "fileCompleted"
   else if pCode is kAlertFileError then
      return "fileError"
   else if pCode is kAlertStorageMoved then
      return "storageMoved"
   else if pCode is kAlertFastresumeRejected then
      return "fastresumeRejected"
   else if pCode is kAlertScrapeReply then
      return "scrapeReply"
   else if pCode is kAlertDhtImmutableItem then
      return "dhtImmutableItem"
   else if pCode is kAlertDhtMutableItem then
      return "dhtMutableItem"
   else if pCode is kAlertDhtPut then
      return "dhtPut"
   else
      return "torrentEvent"
   end if
end handler

-- Walk one bare kvrecord starting at 1-based pStart into an Array, using the
-- field-id -> key mapping. Raw fields become Data; everything else a String
-- (which keeps 64-bit ints and hashes lossless). pEndOut returns the offset
-- just past the record so callers can chain.
private handler _parseRecord(in pData as Data, in pStart as Integer) returns Array
   variable tRec as Array
   variable tOffset as Integer
   variable tCount as Integer
   variable tI as Integer
   variable tId as Integer
   variable tType as Integer
   variable tLen as Integer
   variable tKey as String
   put {} into tRec
   put pStart into tOffset
   put _readU16(pData, tOffset) into tCount
   add 2 to tOffset
   repeat with tI from 1 up to tCount
      put the code of (byte tOffset of pData) into tId
      put the code of (byte (tOffset + 1) of pData) into tType
      add 2 to tOffset
      put _readU16(pData, tOffset) into tLen
      add 2 to tOffset
      put _fieldKey(tId) into tKey
      if tKey is not "" then
         if tType is kTypeRaw then
            if tLen > 0 then
               put byte tOffset to (tOffset + tLen - 1) of pData into tRec[tKey]
            else
               put the empty data into tRec[tKey]
            end if
         else
            put _decodeText(pData, tOffset, tLen) into tRec[tKey]
         end if
      end if
      add tLen to tOffset
   end repeat
   return tRec
end handler

-- ===================================================================== --
--  Public API: lifecycle & diagnostics
-- ===================================================================== --

-- Start THE session. Verifies the ABI first (throws on skew). Returns a
-- positive session handle, or 0 on failure (see btLastError). The app MUST
-- call btStopSession before quitting (no auto unload hook).
public handler btStartSession() returns Integer
   variable tSession as Integer
   _checkABI()
   unsafe
      put _btx_session_new() into tSession
   end unsafe
   return tSession
end handler

-- Pause, flush resume data, destroy, and join the session's threads.
-- Idempotent: a stale handle is a harmless no-op.
public handler btStopSession(in pSession as Integer)
   unsafe
      _btx_session_free(pSession)
   end unsafe
end handler

-- The module-static last-error string ("" when there is no error).
public handler btLastError() returns String
   variable tCount as Integer
   _ensureScratch(kScratchCap)
   unsafe
      put _btx_last_error(sScratchPtr, sScratchCap) into tCount
   end unsafe
   if tCount < 0 then
      _ensureScratch(-tCount)
      unsafe
         put _btx_last_error(sScratchPtr, sScratchCap) into tCount
      end unsafe
   end if
   if tCount <= 0 then
      return ""
   end if
   return _decodeText(_bufToData(sScratchPtr, tCount), 1, tCount)
end handler

public handler btClearError()
   unsafe
      _btx_clear_error()
   end unsafe
end handler

-- ===================================================================== --
--  Public API: session settings (keys map to libtorrent settings_pack names)
-- ===================================================================== --

-- Set an integer setting. pValue is a STRING so 64-bit values cross losslessly.
public handler btSetInt(in pSession as Integer, in pKey as String, in pValue as String) returns Integer
   variable tR as Integer
   unsafe
      put _btx_set_int(pSession, pKey, pValue) into tR
   end unsafe
   return tR
end handler

public handler btSetBool(in pSession as Integer, in pKey as String, in pValue as Boolean) returns Integer
   variable tR as Integer
   variable tV as Integer
   if pValue then
      put 1 into tV
   else
      put 0 into tV
   end if
   unsafe
      put _btx_set_bool(pSession, pKey, tV) into tR
   end unsafe
   return tR
end handler

public handler btSetString(in pSession as Integer, in pKey as String, in pValue as String) returns Integer
   variable tR as Integer
   unsafe
      put _btx_set_str(pSession, pKey, pValue) into tR
   end unsafe
   return tR
end handler

-- Read a setting back as text (diagnostics; not on the hot path).
public handler btGetSetting(in pSession as Integer, in pKey as String) returns String
   variable tCount as Integer
   _ensureScratch(kScratchCap)
   unsafe
      put _btx_get_setting(pSession, pKey, sScratchPtr, sScratchCap) into tCount
   end unsafe
   if tCount < 0 then
      _ensureScratch(-tCount)
      unsafe
         put _btx_get_setting(pSession, pKey, sScratchPtr, sScratchCap) into tCount
      end unsafe
   end if
   if tCount <= 0 then
      return ""
   end if
   return _decodeText(_bufToData(sScratchPtr, tCount), 1, tCount)
end handler

-- MSE / protocol encryption. in/out policy: 0=forced 1=enabled 2=disabled;
-- level: 1=plaintext 2=rc4 3=both.
public handler btSetEncryption(in pSession as Integer, in pIn as Integer, in pOut as Integer, in pLevel as Integer) returns Integer
   variable tR as Integer
   unsafe
      put _btx_set_encryption_policy(pSession, pIn, pOut, pLevel) into tR
   end unsafe
   return tR
end handler

-- ===================================================================== --
--  Public API: add / remove torrents
-- ===================================================================== --

public handler btAddMagnet(in pSession as Integer, in pURI as String, in pSavePath as String) returns Integer
   variable tHandle as Integer
   unsafe
      put _btx_add_magnet(pSession, pURI, pSavePath) into tHandle
   end unsafe
   return tHandle
end handler

-- Add from .torrent BYTES (an input buffer: MCDataGetBytePtr hands C the
-- read-only pointer to the bytes, with their length). Only the metainfo
-- crosses; payload never does.
public handler btAddTorrentFile(in pSession as Integer, in pData as Data, in pSavePath as String) returns Integer
   variable tHandle as Integer
   variable tPtr as Pointer
   put 0 into tHandle
   if the number of bytes in pData > 0 then
      unsafe
         put MCDataGetBytePtr(pData) into tPtr
         put _btx_add_torrent_file(pSession, tPtr, the number of bytes in pData, pSavePath) into tHandle
      end unsafe
   end if
   return tHandle
end handler

public handler btAddTorrentWithResume(in pSession as Integer, in pResume as Data, in pSavePath as String) returns Integer
   variable tHandle as Integer
   variable tPtr as Pointer
   put 0 into tHandle
   if the number of bytes in pResume > 0 then
      unsafe
         put MCDataGetBytePtr(pResume) into tPtr
         put _btx_add_with_resume(pSession, tPtr, the number of bytes in pResume, pSavePath) into tHandle
      end unsafe
   end if
   return tHandle
end handler

public handler btRemoveTorrent(in pSession as Integer, in pTorrent as Integer, in pDeleteFiles as Boolean) returns Integer
   variable tR as Integer
   variable tDel as Integer
   if pDeleteFiles then
      put 1 into tDel
   else
      put 0 into tDel
   end if
   unsafe
      put _btx_remove(pSession, pTorrent, tDel) into tR
   end unsafe
   return tR
end handler

