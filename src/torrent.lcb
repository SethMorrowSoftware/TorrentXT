-- ===================================================================== --
--  Public API: status & inspection (one snapshot per call)
-- ===================================================================== --

-- A status snapshot as an Array (keys: name, state, progress, downloadRate,
-- totalDone, numPeers, savePath, infoHashV1, ...). Empty array on a bad handle.
public handler btTorrentStatus(in pTorrent as Integer) returns Array
   variable tCount as Integer
   _ensureStatus(kStatusCap)
   unsafe
      put _btx_torrent_status(pTorrent, sStatusPtr, sStatusCap) into tCount
   end unsafe
   if tCount < 0 then
      _ensureStatus(-tCount)
      unsafe
         put _btx_torrent_status(pTorrent, sStatusPtr, sStatusCap) into tCount
      end unsafe
   end if
   if tCount <= 0 then
      return {}
   end if
   return _parseRecord(_bufToData(sStatusPtr, tCount), 1)
end handler

public handler btTorrentCount(in pSession as Integer) returns Integer
   variable tR as Integer
   unsafe
      put _btx_torrent_count(pSession) into tR
