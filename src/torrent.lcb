-- ===================================================================== --
--  Engine Foundation <builtin> foreign handlers
-- ===================================================================== --
-- These bind to the engine's own libfoundation, not to our shim. They are the
-- sanctioned bridge between LCB Data/Pointer and raw C buffers - an LCB Data does
-- NOT auto-bridge to a void* (Language Reference: "No automatic bridging from
-- Data or String to Pointer exists"). Verified against the htmltidy and HIDAPI
-- bindings and libfoundation/foundation.h. Declared here, before any helper uses
-- them (OXT resolves identifiers by lexical position).
--
-- NOTE: a `<builtin>` handler resolves by its NAME matching the engine symbol, so
-- these - unlike every other private handler in this file - carry NO leading `_`.
-- Renaming any of them breaks the binding.
--   * MCStringDecode: bytes -> String (UTF-8); kEncodingUtf8 == 4.
--   * MCMemoryAllocate/Deallocate: a raw writable block for the OUTPUT buffers C
--     fills. The size is pointer-width (UIntSize).
--   * MCDataCreateWithBytes: copy the C-written bytes back into a Data we walk.
--     A Data's byte count is uindex_t == uint32 (CUInt).
--   * MCDataGetBytePtr: the read-only pointer to a Data's own bytes, for the
--     INPUT buffers C reads (never written through - it is a const byte_t*).
private foreign handler MCStringDecode(in pData as Data, in pEncoding as CInt, in pIsExternalRep as CBool, out rString as String) returns CBool binds to "<builtin>"
private foreign handler MCMemoryAllocate(in pSize as UIntSize, out rBlock as Pointer) returns CBool binds to "<builtin>"
private foreign handler MCMemoryDeallocate(in pBlock as Pointer) returns nothing binds to "<builtin>"
private foreign handler MCDataCreateWithBytes(in pBytes as Pointer, in pCount as CUInt, out rData as Data) returns CBool binds to "<builtin>"
private foreign handler MCDataGetBytePtr(in pData as Data) returns Pointer binds to "<builtin>"

-- ===================================================================== --
--  Private helpers
-- ===================================================================== --

-- Throw a clear error if the loaded native library's ABI does not match this
-- binding (plan section 4.5). Better a legible throw at startup than a crash.
private handler _checkABI()
   variable tABI as Integer
   unsafe
      put _btx_abi_version() into tABI
   end unsafe
   if tABI is not kABIVersion then
      throw "TorrentXT native library ABI does not match the LCB binding; rebuild and repackage the native library."
   end if
end handler

-- Ensure the reusable drain buffer is allocated to at least pNeed bytes. A grow
-- frees the old block and allocates a fresh one (MCMemoryReallocate is not a
-- confirmed <builtin>); a grow only happens when the shim reports a -needed past
-- the current capacity, which is rare. The capacity (0 until first allocation)
-- doubles as the "is it allocated?" flag, so we never read an unset Pointer.
private handler _ensureDrain(in pNeed as Integer)
   variable tOk as Boolean
   if sDrainCap < pNeed then
      if sDrainCap > 0 then
         unsafe
            MCMemoryDeallocate(sDrainPtr)
         end unsafe
      end if
      put false into tOk
      unsafe
         put MCMemoryAllocate(pNeed, sDrainPtr) into tOk
      end unsafe
      if not tOk then
         throw "TorrentXT: failed to allocate the drain buffer."
      end if
      put pNeed into sDrainCap
   end if
end handler

private handler _ensureStatus(in pNeed as Integer)
   variable tOk as Boolean
   if sStatusCap < pNeed then
      if sStatusCap > 0 then
         unsafe
            MCMemoryDeallocate(sStatusPtr)
         end unsafe
      end if
      put false into tOk
      unsafe
         put MCMemoryAllocate(pNeed, sStatusPtr) into tOk
      end unsafe
      if not tOk then
         throw "TorrentXT: failed to allocate the status buffer."
      end if
      put pNeed into sStatusCap
   end if
end handler

private handler _ensureScratch(in pNeed as Integer)
   variable tOk as Boolean
   if sScratchCap < pNeed then
      if sScratchCap > 0 then
         unsafe
            MCMemoryDeallocate(sScratchPtr)
         end unsafe
      end if
      put false into tOk
      unsafe
         put MCMemoryAllocate(pNeed, sScratchPtr) into tOk
      end unsafe
      if not tOk then
         throw "TorrentXT: failed to allocate the scratch buffer."
      end if
      put pNeed into sScratchCap
   end if
end handler

-- Copy the pLen bytes the shim wrote into our raw buffer back into a fresh Data
-- the record walkers can index by byte (MCDataCreateWithBytes, verified
-- <builtin>). Empty Data on a non-positive length or an allocation failure.
private handler _bufToData(in pPtr as Pointer, in pLen as Integer) returns Data
   variable tData as Data
   variable tOk as Boolean
   put the empty data into tData
   if pLen > 0 then
      put false into tOk
      unsafe
         put MCDataCreateWithBytes(pPtr, pLen, tData) into tOk
      end unsafe
      if not tOk then
         put the empty data into tData
      end if
   end if
   return tData
end handler

-- Read a big-endian u16 at 1-based byte offset pOffset (the wire is network
-- order; this is the inverse of the shim's put_u16).
private handler _readU16(in pData as Data, in pOffset as Integer) returns Integer
   variable tHi as Integer
   variable tLo as Integer
   put the code of (byte pOffset of pData) into tHi
   put the code of (byte (pOffset + 1) of pData) into tLo
   return tHi * 256 + tLo
end handler

-- Decode pLen bytes of UTF-8 (1-based pStart) into a String via the engine's
-- MCStringDecode (declared above); LCB has no `textDecode` handler.
private handler _decodeText(in pData as Data, in pStart as Integer, in pLen as Integer) returns String
   variable tSub as Data
   variable tStr as String
   variable tOk as Boolean
   if pLen <= 0 then
      return ""
   end if
   put byte pStart to (pStart + pLen - 1) of pData into tSub
   put "" into tStr
   unsafe
      put MCStringDecode(tSub, kEncodingUtf8, false, tStr) into tOk
   end unsafe
   if tOk then
      return tStr
   end if
   return ""
end handler

-- Map a record field id to its script-facing array key. "" means "skip"
-- (an unknown id, which the registry checker prevents in practice).
private handler _fieldKey(in pId as Integer) returns String
   if pId is kFieldName then
      return "name"
   else if pId is kFieldState then
      return "state"
   else if pId is kFieldProgress then
      return "progress"
   else if pId is kFieldDownloadRate then
      return "downloadRate"
   else if pId is kFieldUploadRate then
      return "uploadRate"
   else if pId is kFieldTotalDone then
      return "totalDone"
   else if pId is kFieldTotalWanted then
      return "totalWanted"
   else if pId is kFieldNumPeers then
      return "numPeers"
   else if pId is kFieldNumSeeds then
      return "numSeeds"
   else if pId is kFieldSavePath then
      return "savePath"
   else if pId is kFieldInfoHashV1 then
      return "infoHashV1"
