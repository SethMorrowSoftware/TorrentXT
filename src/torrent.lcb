-- Opaque DHT routing-table state for persistence across runs.
public handler btDhtSaveState(in pSession as Integer) returns Data
   variable tCount as Integer
   _ensureStatus(kStatusCap)
   unsafe
      put _btx_dht_save_state(pSession, sStatusPtr, sStatusCap) into tCount
   end unsafe
   if tCount < 0 then
      _ensureStatus(-tCount)
      unsafe
